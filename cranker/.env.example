# Solana
SOLANA_RPC=https://api.mainnet-beta.solana.com
SOLANA_KEYPAIR_PATH=/path/to/keypair.json

# Ethereum
ETH_RPC=https://eth.llamarpc.com
ETH_PRIVATE_KEY=0x...

# Base
BASE_RPC=https://mainnet.base.org
BASE_PRIVATE_KEY=0x...

# Arbitrum
ARB_RPC=https://arb1.arbitrum.io/rpc

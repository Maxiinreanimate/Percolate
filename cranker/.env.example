# Loop intervals (ms)
LIQUIDATION_INTERVAL=2000
TRIGGER_INTERVAL=1000
FUNDING_INTERVAL=60000
PEG_INTERVAL=10000
ADAPTIVE_K_INTERVAL=60000

# Logging
LOG_LEVEL=info
